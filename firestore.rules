rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ====================================
    // LOCATIONS COLLECTION
    // ====================================
    // Public read access for all users
    // Only admins can write (managed via Firebase Console)
    match /locations/{locationId} {
      allow read: if true;  // Anyone can view locations
      allow write: if false;  // Prevent client-side writes
    }
    
    // ====================================
    // CATEGORIES COLLECTION
    // ====================================
    // Public read, admin-only write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;  // Managed via Firebase Console only
    }
    
    // ====================================
    // PRODUCTS COLLECTION
    // ====================================
    // Public read, admin-only write
    match /products/{productId} {
      allow read: if true;
      allow write: if false;  // Managed via Firebase Console only
    }
    
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ====================================
    // ORDERS COLLECTION
    // ====================================
    match /orders/{orderId} {
      // Users can only access their own orders. Admins can access all.
      allow create: if request.auth != null && 
                       request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // ====================================
    // USERS COLLECTION
    // ====================================
    // Users can only access their own data. Admins can access all.
    match /users/{userId} {
      allow create: if request.auth != null && 
                       request.auth.uid == userId;
      allow read: if request.auth != null && 
                     (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null && 
                       (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
    
    // ====================================
    // FAVORITES COLLECTION
    // ====================================
    // Users can only access their own favorites
    match /favorites/{userId} {
      allow read, write: if request.auth != null && 
                           request.auth.uid == userId;
    }
  }
}
